# Feelms Admin Panel — environment variables

# Port for the Vite dev server (required)
PORT=5174

# Base path if running on a subpath (default: /)
BASE_PATH=/

# API server URL — all /api requests are proxied here
VITE_API_URL=http://localhost:3001

# Admin panel URL (for CORS/reference)
VITE_ADMIN_URL=https://admin.feelms.tv
