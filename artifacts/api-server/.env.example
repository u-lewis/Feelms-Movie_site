# Feelms API Server — environment variables

# Server port
PORT=3001

# PostgreSQL database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/feelms

# JWT signing secret — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Public site URL (used for CORS and SEO sitemap)
SITE_URL=https://feelms.tv

# Admin panel URL (for CORS)
ADMIN_URL=https://admin.feelms.tv

# Admin contact email (used in settings defaults)
ADMIN_EMAIL=admin@feelms.tv

# SendGrid / email provider API key (for OTP delivery)
SENDGRID_API_KEY=

# Email sender address
EMAIL_FROM=no-reply@feelms.tv

# Node environment
NODE_ENV=production
