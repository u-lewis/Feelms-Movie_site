{
  "buildCommand": "pnpm --filter @workspace/feelms build",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://workspaceapi-server-production-bf58.up.railway.app/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
