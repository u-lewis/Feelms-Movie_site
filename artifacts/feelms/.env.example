# Feelms Public Site — environment variables

# Port for the Vite dev server (required)
PORT=5173

# Base path if running on a subpath (default: /)
BASE_PATH=/

# API server URL — all /api requests are proxied here
VITE_API_URL=http://localhost:3001

# Site URL (used for SEO and canonical links)
VITE_SITE_URL=https://feelms.tv
